---
const reviews = [
  { name: "Petar Kamenecki", date: "Prije 2 tjedna", text: "The servers are very polite, and even though it's a small location near the gas station, it has personality and a generally likeable vibe to it; it's enjoyable to stay in there! The food itself is fabulous..." },
  { name: "Arna Ksi", date: "Prije 3 mjeseca", text: "Went today for the first time and will definitely be back. There are only four types of burgers on the menu, but what more do you need… They’re simple, made with straightforward ingredients, well-crafted, and really tasty." },
  { name: "Ales Horvatek", date: "Prije 4 mjeseca", text: "This is a fantastic burger, easily one of the best I've had recently and a guaranteed spot in my Top 5 burger joints in the Zagreb area. If you consider yourself a burger enthusiast, this place is a must-try." },
  { name: "Dean Zulich", date: "Prije 4 mjeseca", text: "Great Burger overall, high quality ingredients yet simple and delicious. Staff is on point too." },
  { name: "Liudmyla Dziubynska", date: "Prije godinu dana", text: "Now I understand why it has so big rating. It's the best service in Croatia that I had! The food was good." },
  { name: "Kris", date: "Prije 3 mjeseca", text: "Outstanding smash burger. Really really good." },
  { name: "Ljubiša Kukulj", date: "Prije 5 mjeseci", text: "Really nice place with just enough options of food and drinks. Nothing special but yet... that's actually what makes this place good." },
  { name: "Ivan Čihoratić", date: "Prije 11 mjeseci", text: "Omg….I was a bit sceptical because of the location, but it was probably the best burger I ever had, the service was fast and the staff was nice and welcoming. Price was lower then most places in the city considering the quality you get." },
  { name: "Ivan Marlović", date: "Prije godinu dana", text: "Just amazing! 👌 A real gem of a burger place in Zagreb!" },
  { name: "Luka", date: "Prije godinu dana", text: "It is safe to say that these are the most delicious burgers I have ever tasted. Nothing else compares to them. The best part is that the burgers are served exactly as they are shown in the picture on the menu..." },
  { name: "Stipe Pavicic", date: "Prije 4 mjeseca", text: "Super friendly stuff and burgers are simply delicious. Highly recommend to visit" },
  { name: "Juan Manuel Marin", date: "Prije godinu dana", text: "Excellent service. Fresh food including the fries and the bread. Unexpectedly good to be a gas station restaurant. Top three best burgers in Zagreb" },
  { name: "David Despot", date: "Prije godinu dana", text: "Amazing smash burgers the best i ever ate in croatia and very friendly and nice staff and service. 10/10 rating. Dont let the not so nice location fool you, this is surely one of the best smash burgers you will try" },
  { name: "Sena Bena", date: "Prije godinu dana", text: "The BEST burger I ate in my whole life. I had the ljuti burger menu. So so tasty😍😍😍 The guy working there was super friendly. Kudos for the great service." },
  { name: "Matt Freeman", date: "Prije godinu dana", text: "This place is easily the best burger in Zagreb! Menu is small and just right!" },
  { name: "Fran Globlek", date: "Prije godinu dana", text: "Seriously good. We had two classic smash burgers as we never tried this type of burger before. I'm not a fan of the location though." },
  { name: "Shaquille Petersen", date: "Prije godinu dana", text: "Fast service and delicious smash burgers, the best I’ve tried!!! Good customer service as well. Good prices, definitely would come more than once a week." },
  { name: "garazhni boker", date: "Prije 8 mjeseci", text: "simple burgers, excellent quality ingredients. good staff 10/10" }
];

// Duplicate reviews to create a seamless infinite loop
const infiniteReviews = [...reviews, ...reviews];
---

<section id="reviews" class="py-20 bg-[#111111] overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      
      <!-- Better Google Logo and Rating Header -->
      <div class="inline-flex items-center justify-center gap-3 mb-4 bg-[#1a1a1a] px-6 py-3 rounded-full border border-gray-800 shadow-[0_0_20px_rgba(255,255,255,0.03)] hover:border-gray-700 transition">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="w-8 h-8">
          <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
          <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
          <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
        </svg>
        <span class="text-2xl font-bold text-white tracking-tight">Recenzije</span>
      </div>

      <div class="flex flex-col items-center justify-center">
        <div class="flex items-end gap-3 mb-2">
          <span class="text-6xl font-black text-white leading-none">4.8</span>
          <div class="flex flex-col items-start pb-1">
            <div class="flex text-yellow-400 gap-1">
              {Array.from({ length: 5 }).map(() => (
                <svg class="w-6 h-6 fill-current drop-shadow-[0_0_8px_rgba(250,204,21,0.4)]" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
              ))}
            </div>
          </div>
        </div>
        <p class="text-gray-400 text-sm font-medium tracking-widest mt-1">NA TEMELJU 671 RECENZIJE</p>
      </div>
    </div>

    <!-- Infinite Auto-Scrolling Marquee -->
    <div class="marquee-container w-full relative">
      <!-- Gradient Fades on edges for depth effect -->
      <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-[#111111] to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-[#111111] to-transparent z-10 pointer-events-none"></div>
      
      <div class="marquee-content flex gap-6 py-4">
        {infiniteReviews.map(review => (
          <div class="marquee-item shrink-0 w-[350px] bg-[#1a1a1a]/80 backdrop-blur-sm p-8 rounded-3xl border border-gray-800 flex flex-col justify-between hover:border-yellow-400/30 hover:bg-[#222] transition-colors relative group">
            
            <!-- Small Google icon in top right card corner -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="w-5 h-5 absolute top-6 right-6 opacity-30 group-hover:opacity-100 transition-opacity duration-300">
              <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
              <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
              <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
              <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>

            <div>
              <div class="flex items-center mb-6">
                <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-purple-600 shadow-inner text-white rounded-full flex items-center justify-center font-bold text-xl mr-4 shadow-lg shrink-0">
                  {review.name.charAt(0)}
                </div>
                <div>
                  <h3 class="font-bold text-white text-lg leading-tight truncate w-48">{review.name}</h3>
                  <p class="text-sm text-gray-500 mt-0.5">{review.date}</p>
                </div>
              </div>
              <div class="flex text-yellow-400 mb-4 gap-0.5">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                ))}
              </div>
              <p class="text-gray-300 md:text-base text-sm leading-relaxed" style="display: -webkit-box; -webkit-line-clamp: 5; -webkit-box-orient: vertical; overflow: hidden;">
                "{review.text}"
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .marquee-container {
    mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    /* For browser compatibility */
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .marquee-content {
    display: flex;
    width: max-content;
    animation: scroll 66s linear infinite;
  }

  /* Pauziraj animaciju kad korisnik stavi mis iznad */
  .marquee-content:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      /* Pomiče se prema lijevo za točno polovicu širine kontejnera (budući da su arrayevi uduplani) */
      transform: translateX(calc(-50% - 12px)); /* -12px radi gap-a */
    }
  }
</style>