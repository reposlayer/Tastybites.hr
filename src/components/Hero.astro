<section class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden">
    <!-- Pozadinska slika -->
    <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-t from-darker via-darker/80 to-transparent z-10"></div>
        <img class="w-full h-full object-cover opacity-60" src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?q=80&w=2600&auto=format&fit=crop" alt="Smash Burger">
    </div>

    <!-- Sadržaj -->
    <div class="relative z-20 text-center container px-4 sm:px-6">
        <h1 class="text-6xl md:text-8xl font-display font-bold uppercase tracking-tight text-white mb-6">
            Pravi <span class="text-primary">Smash</span> <br/> U Zagrebu.
        </h1>
        <p class="text-xl md:text-3xl text-gray-300 font-medium mb-10 max-w-2xl mx-auto">
            Hrskavi rubovi, sočna sredina i vrhunski krumpirići. 
        </p>
        <div class="flex flex-col sm:flex-row gap-6 justify-center">
            <a href="https://wolt.com/en/hrv/zagreb/restaurant/tasty-bitess?srsltid=AfmBOoqJdvC635NXjIFeLShzdwKX_5GPf9md631uCzuclzlhLX0lMwp6"
               target="_blank" rel="noopener noreferrer"
               class="bg-primary hover:bg-accent text-white px-10 py-5 rounded-full font-bold text-lg md:text-xl transition-all transform hover:scale-105 shadow-xl shadow-primary/20 flex items-center justify-center gap-3">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 9l2-4h10l2 4" /><path d="M3 9h18v12H3z" /><path d="M16 13a4 4 0 01-8 0" /></svg>
                Naruči. na Woltu
            </a>
            <a href="#menu" class="border-2 border-white/20 hover:border-white/50 bg-white/5 backdrop-blur-sm text-white px-10 py-5 rounded-full font-bold text-lg md:text-xl transition-all flex items-center justify-center">
                Pogledaj Meni
            </a>
        </div>
    </div>
</section>
