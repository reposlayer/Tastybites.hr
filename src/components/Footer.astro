---
---
<footer id="lokacija" class="bg-dark text-gray-400 py-20 px-6 lg:px-12 border-t border-white/5">
    <div class="container mx-auto max-w-6xl grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-16 md:gap-8">
        
        <!-- Branding & Info -->
        <div class="space-y-6">
            <div class="flex items-center gap-4 mb-4">
                <img src="/logo.jpeg" alt="Tasty Bites Logo" class="h-16 w-auto rounded-xl shadow-lg border border-white/10 bg-black" />
                <h2 class="text-4xl font-display font-bold text-white tracking-widest uppercase">
                    Tasty<span class="text-primary">Bites</span>
                </h2>
            </div>
            <p class="leading-relaxed text-md text-gray-400">
                Specijalisti za vrhunske Smash burgere u centru Zagreba. Pripremljeni s ljubavlju od svježih, kvalitetnih sastojaka.
            </p>
        </div>

        <!-- Kontakt -->
        <div class="space-y-6">
            <h3 class="text-white font-bold font-sans text-xl uppercase mb-4 text-primary">Kontakt</h3>
            <ul class="space-y-3 font-medium">
                <li class="flex items-center gap-3">
                    <svg class="text-primary w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    Ulica Kneza Branimira 103b, Zagreb
                </li>
                <li class="flex items-center gap-3">
                    <svg class="text-primary w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                    <a href="tel:+385916063457" class="hover:text-white transition-colors">+385 91 606 3457</a>
                </li>
            </ul>
        </div>

        <!-- Radno vrijeme i Karta -->
        <div class="space-y-6">
            <h3 class="text-white font-bold font-sans text-xl uppercase mb-4 text-primary">Radno vrijeme i lokacija</h3>
            <ul class="space-y-2 font-medium bg-white/5 rounded-2xl p-6 border border-white/10 mb-6">
                <li class="flex justify-between"><span>Pon - Sub</span> <span class="text-white">12:00 - 22:00</span></li>
                <li class="flex justify-between"><span>Nedjelja</span> <span class="text-white">Zatvoreno</span></li>
            </ul>
            <div class="w-full h-48 rounded-2xl overflow-hidden border border-white/10">
                <iframe 
                    src="https://maps.google.com/maps?q=Ulica%20Kneza%20Branimira%20103b,%20Zagreb&t=&z=15&ie=UTF8&iwloc=&output=embed" 
                    width="100%" 
                    height="100%" 
                    style="border:0;" 
                    allowfullscreen="" 
                    loading="lazy">
                </iframe>
            </div>
        </div>

    </div>

    <!-- Bottom -->
    <div class="container mx-auto max-w-6xl mt-20 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4 text-sm font-medium">
        <p>&copy; {new Date().getFullYear()} Tasty Bites. Sva prava pridržana.</p>
        <div class="flex gap-6">
            <a href="#" class="hover:text-primary transition-colors">Privacy Policy</a>
            <a href="#" class="hover:text-primary transition-colors">Terms of Service</a>
        </div>
    </div>
</footer>