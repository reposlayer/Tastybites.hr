---
const burgers = [
    { name: "Tasty smash", desc: "2x 100% juneći odrezak, američki sir, brioche pecivo, pečeni luk, Tasty umak", price: "11.50 €" },
    { name: "Truffle smash", desc: "2x 100% juneći odrezak, americki sir, brioche pecivo, rikula, krema od tartufa", price: "11.50 €" },
    { name: "Classic smash", desc: "2x 100% juneći odrezak, američki sir, brioche pecivo, zelena salata, rajčica, kiseli krastavci, Tasty umak", price: "11.50 €" },
    { name: "Ljuti smash", desc: "2x 100% juneći odrezak, američki sir, brioche pecivo, zelena salata, jalapeno papričice, ljuti Tasty umak, chili pahuljice", price: "11.50 €" }
];

const burgerMenus = [
    { name: "Classic Smash menu", desc: "2x 100% juneći odrezak, američki sir, brioche pecivo, zelena salata, rajčica, kiseli krastavci, Tasty umak, pommes frites, coca-cola 0.33", price: "14.20 €" },
    { name: "Ljuti Smash menu", desc: "2x 100% juneći odrezak, američki sir, brioche pecivo, zelena salata, jalapeno papričice, ljuti Tasty umak, pommes frites, coca-cola 0.33", price: "14.20 €" },
    { name: "Tasty Smash menu", desc: "2x 100% juneći odrezak, američki sir, brioche pecivo, pečeni luk, Tasty umak, pommes frites, coca-cola 0.33", price: "14.20 €" },
    { name: "Truffle Smash menu", desc: "2x 100% juneći odrezak, americki sir, brioche pecivo, rikula, krema od tartufa, coca-cola 0.33", price: "14.20 €" }
];

const sides = [
    { name: "Garlic Fries", desc: "Veliki pommes sa majonezom od češnjaka.", price: "6.00 €" }
];

const drinks = [
    { name: "Coca-Cola", price: "2.50 €" }
];
---
<section id="menu" class="py-24 bg-darker text-white">
    <div class="container mx-auto px-6 max-w-6xl">
        <h2 class="text-5xl md:text-6xl font-display font-bold text-center mb-16 uppercase text-white">Naš <span class="text-primary">Meni</span></h2>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
            
            <!-- Burgers Column -->
            <div class="space-y-16">
                <div>
                    <h3 class="text-3xl font-display font-bold border-b border-white/10 pb-4 mb-8 text-primary">Samo Burgeri</h3>
                    <div class="space-y-8">
                        {burgers.map(item => (
                            <div class="group">
                                <div class="flex justify-between items-baseline mb-2 gap-4">
                                    <h4 class="text-xl font-bold font-sans uppercase tracking-wide group-hover:text-primary transition-colors">{item.name}</h4>
                                    <span class="text-xl font-bold font-display text-primary whitespace-nowrap">{item.price}</span>
                                </div>
                                <p class="text-gray-400 text-sm leading-relaxed">{item.desc}</p>
                            </div>
                        ))}
                    </div>
                </div>
            </div>

            <!-- Burger Menus & Sides Column -->
            <div class="space-y-16">
                <!-- Burger Menus -->
                <div>
                    <h3 class="text-3xl font-display font-bold border-b border-white/10 pb-4 mb-8 text-primary">Burger Menu <span class="text-sm font-sans font-normal text-gray-400 normal-case ml-2">(Fries, Coca-Cola 0.33, Ketchup)</span></h3>
                    <div class="space-y-8">
                        {burgerMenus.map(item => (
                            <div class="group">
                                <div class="flex justify-between items-baseline mb-2 gap-4">
                                    <h4 class="text-xl font-bold font-sans uppercase tracking-wide group-hover:text-primary transition-colors">{item.name}</h4>
                                    <span class="text-xl font-bold font-display text-primary whitespace-nowrap">{item.price}</span>
                                </div>
                                <p class="text-gray-400 text-sm leading-relaxed">{item.desc}</p>
                            </div>
                        ))}
                    </div>
                </div>

                <!-- Prilozi i Pića Combo -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
                    <div>
                        <h3 class="text-2xl font-display font-bold border-b border-white/10 pb-3 mb-6 text-primary">Prilozi</h3>
                        <div class="space-y-6">
                            {sides.map(item => (
                                <div class="group">
                                    <div class="flex justify-between items-baseline mb-2 gap-4">
                                        <h4 class="text-lg font-bold font-sans uppercase tracking-wide group-hover:text-primary transition-colors">{item.name}</h4>
                                        <span class="text-lg font-bold font-display text-primary whitespace-nowrap">{item.price}</span>
                                    </div>
                                    <p class="text-gray-400 text-sm leading-relaxed">{item.desc}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                    <div>
                        <h3 class="text-2xl font-display font-bold border-b border-white/10 pb-3 mb-6 text-primary">Pića</h3>
                        <div class="space-y-4">
                            {drinks.map(item => (
                                <div class="flex justify-between items-baseline border-b border-white/5 pb-2">
                                    <h4 class="text-sm font-sans uppercase text-gray-300">{item.name}</h4>
                                    <span class="text-sm font-bold font-display text-primary">{item.price}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
            
        </div>

        <div class="mt-20 text-center">
            <a href="https://wolt.com/en/hrv/zagreb/restaurant/tasty-bitess" class="inline-flex bg-primary hover:bg-accent text-white px-10 py-5 rounded-full font-bold text-lg md:text-xl transition-all transform hover:scale-105 shadow-xl shadow-primary/20 items-center justify-center gap-3">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 9l2-4h10l2 4" /><path d="M3 9h18v12H3z" /><path d="M16 13a4 4 0 01-8 0" /></svg>
                Naruči na Woltu
            </a>
            <p class="text-gray-500 mt-4 text-sm">*Cijene i dostupnost podložne su brzoj dostavi i promjenama na Wolt platformi.</p>
        </div>
    </div>
</section>