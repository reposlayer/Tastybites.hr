---
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import Menu from '../components/Menu.astro';
import Reviews from '../components/Reviews.astro';
import Gallery from '../components/Gallery.astro';
import Footer from '../components/Footer.astro';
---

<html lang="hr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tasty Bites | Smash Burgers & Fries - Zagreb</title>
    <meta name="description" content="Najbolji smash burgeri u Zagrebu! Naručite odmah preko Wolta. Ulica Kneza Branimira 103b." />
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo.png" />
    
    <!-- Open Graph / thumbnail preview za društvene mreže (WhatsApp, iMessage, Facebook) -->
    <meta property="og:title" content="Tasty Bites | Najbolji Smash Burgeri u Zagrebu" />
    <meta property="og:description" content="Hrskavi rubovi, sočna sredina i vrhunski krumpirići. Naručite online ili nas posjetite na adresi Kneza Branimira 103b." />
    <meta property="og:image" content="/logo.png" />
    <meta property="og:url" content="https://tastybites.hr" />
    <meta property="og:type" content="website" />
    
    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Tasty Bites | Najbolji Smash Burgeri u Zagrebu" />
    <meta name="twitter:description" content="Hrskavi rubovi, sočna sredina i vrhunski krumpirići. Naručite online ili nas posjetite na adresi Kneza Branimira 103b." />
    <meta name="twitter:image" content="/logo.png" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Oswald:wght@500;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-darker text-white font-sans antialiased">
    <Navigation />
    <main>
      <Hero />
      <Menu />
      <Gallery />
      <Reviews />
    </main>
    <Footer />
    <style is:global>
      /* Final Polish: Smooth scrolling za anchor linkove (npr. klik na 'Jelovnik' u navigaciji) */
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 5rem; /* da navigacija ne prekrije naslov */
      }
      
      /* Lagani fade-in efekt učitavanja */
      body {
        animation: fadeIn 0.8s ease-out forwards;
      }
      
      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
    </style>
  </body>
</html>
